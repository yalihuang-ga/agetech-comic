# 應用程式
APP_NAME=AgeTech Comic Backend
DEBUG=true
# dev 模式允許用 X-Debug-User 標頭帶入假 user_id（跳過 LINE 驗證）
ENV=dev

# LINE Bot 憑證（於 https://developers.line.biz 取得；P1 才需要）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Vertex AI 圖片生成（Nano Banana 2 / Gemini 3 Pro Image）
# 認證走 GCP ADC：gcloud auth application-default login
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global
VERTEX_IMAGE_MODEL=gemini-3-pro-image
# 生圖失敗時是否回傳佔位結果（本機無 GCP 權限時設 true 仍可跑流程）
IMAGE_GEN_FALLBACK=true

# PocketBase（DB + 圖檔儲存；docker-compose 內用 http://pocketbase:8090）
POCKETBASE_URL=http://localhost:8090
# 回給前端的圖檔公開網址（瀏覽器可連）。docker-compose 時設為對外位址。
POCKETBASE_PUBLIC_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@agetech.local
POCKETBASE_ADMIN_PASSWORD=changeme123
PERSIST_DIARIES=true

# CORS：允許的前端來源（JSON 陣列格式）
CORS_ORIGINS=["http://localhost:3000"]
